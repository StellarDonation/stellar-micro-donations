# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/stellar-donations

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Encryption Configuration - CRITICAL FOR SECURITY
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-this-in-production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Anchor Configuration (for currency conversion)
ANCHOR_DOMAIN=your-anchor-domain.com
ANCHOR_API_KEY=your-anchor-api-key

# Albedo Wallet (optional)
ALBEDO_APP_URL=http://localhost:3001
